# ─── Kinetic Integrity Monitor · Environment Variables ───────────────────────
# Copy to .env and fill in your values before running docker-compose up

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
# Used by Docker Compose; override POSTGRES_URL for external databases
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_URL=postgresql://kinetic:change_me_to_a_strong_password@postgres:5432/kinetic

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SELLAR_URL=https://fredericgeski.selar.com/727l48e1z1

# ── Optional: Email notifications ─────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=no-reply@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=Kinetic <no-reply@example.com>
